{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "daily-news-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-06-16",
  "kv_namespaces": [
    {
      "binding": "DAILY_NEWS",
      "id": "00000000000000000000000000000000"
    }
  ],
  "triggers": {
    "crons": [
      "30 0 * * *"
    ]
  }
}
